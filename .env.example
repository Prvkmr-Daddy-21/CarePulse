

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Database Connection Atlas URI string
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# Security Token secrets
JWT_SECRET="YOUR_ACCESS_JWT_SECRET_STRING_OR_RANDOM_HASH"
JWT_REFRESH_SECRET="YOUR_REFRESH_JWT_SECRET_STRING_OR_RANDOM_HASH"

# Optional SMTP client parameters for active notification alerts
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
